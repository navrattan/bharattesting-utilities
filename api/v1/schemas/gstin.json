{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GSTIN Record",
  "type": "object",
  "properties": {
    "gstin": {
      "type": "string",
      "pattern": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z][0-9A-Z]Z[0-9A-Z]$"
    },
    "pan": {
      "type": "string"
    },
    "state_code": {
      "type": "string"
    }
  },
  "required": ["gstin", "pan", "state_code"]
}
