{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aadhaar Record",
  "type": "object",
  "properties": {
    "number": {
      "type": "string",
      "pattern": "^[2-9][0-9]{11}$",
      "description": "12-digit Aadhaar number with valid Verhoeff checksum"
    },
    "formatted": {
      "type": "string",
      "pattern": "^[2-9][0-9]{3}\\s[0-9]{4}\\s[0-9]{4}$",
      "description": "Aadhaar number in XXXX XXXX XXXX format"
    }
  },
  "required": ["number", "formatted"]
}
