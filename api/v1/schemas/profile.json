{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Indian User Profile",
  "type": "object",
  "properties": {
    "name": {
      "type": "object",
      "properties": {
        "first": { "type": "string" },
        "last": { "type": "string" },
        "full": { "type": "string" }
      }
    },
    "aadhaar": { "type": "string", "pattern": "^[2-9][0-9]{11}$" },
    "pan": { "type": "string", "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]$" },
    "phone": { "type": "string", "pattern": "^\\+91-[0-9]{3}-[0-9]{7}$" },
    "email": { "type": "string", "format": "email" },
    "address": {
      "type": "object",
      "properties": {
        "line1": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "pincode": { "type": "string", "pattern": "^[0-9]{6}$" }
      }
    }
  },
  "required": ["name", "aadhaar", "pan", "phone", "address"]
}
