<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="flutter.secure_storage" />
        <exclude domain="sharedpref" path="camera_settings" />

        <!-- Include only essential data -->
        <include domain="file" path="." />
    </cloud-backup>

    <device-transfer>
        <!-- Similar rules for device transfer -->
        <exclude domain="sharedpref" path="flutter.secure_storage" />
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>