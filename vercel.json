{
  "buildCommand": "cd app && flutter build web --release --web-renderer canvaskit --base-href /",
  "outputDirectory": "app/build/web",
  "installCommand": "flutter pub get",
  "framework": null,
  "functions": {},
  "headers": [
    {
      "source": "/(.*).(js|css|woff2|woff|ttf|eot|svg|ico|png|jpg|jpeg|gif|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false,
  "github": {
    "enabled": true,
    "autoAlias": true
  }
}